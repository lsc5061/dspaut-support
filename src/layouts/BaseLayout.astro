---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
}

const lang = Astro.currentLocale || "ko";

const { 
	title = "DSPAUT Support", 
	description = lang === "ko" ? "DSPAUT 제품 매뉴얼 및 기술 지원 포털입니다." : "DSPAUT product manuals and technical support portal."
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts: Inter & Outfit -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		
		<title>{title}</title>

		<!-- 테마 초기화 스크립트 (깜빡임 방지) -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			document.documentElement.setAttribute('data-theme', theme);
		</script>
	</head>
	<body class="bg-base-100 text-base-content antialiased font-sans">
		<div class="drawer drawer-end">
			<input id="mobile-drawer" type="checkbox" class="drawer-toggle" />
			<div class="drawer-content flex flex-col min-h-screen">
				<Navbar />
				
				<main class="flex-grow">
					<slot />
				</main>
				
				<Footer />
			</div> 
			<div class="drawer-side z-[100]">
				<label for="mobile-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
				<div class="w-80 min-h-full bg-base-100 text-base-content shadow-xl">
					<div class="p-6 border-b border-base-200 flex justify-between items-center bg-base-200/30">
						<span class="font-black text-xs tracking-[0.2em] text-primary">MENU</span>
						<label for="mobile-drawer" class="btn btn-ghost btn-xs btn-circle opacity-50">✕</label>
					</div>
					<div class="overflow-y-auto">
						<!-- Global Mobile Menu Links -->
						<div class="p-6 border-b border-base-200 lg:hidden">
							<ul class="menu menu-vertical p-0 gap-4 text-base font-bold tracking-tight">
								<li><a href={`/${lang}/manual`} class="hover:text-primary transition-all">MANUAL</a></li>
								<li><a href={`/${lang}/blog`} class="hover:text-primary transition-all">BLOG</a></li>
								<li><a href={`/${lang}/study`} class="hover:text-primary transition-all">STUDY</a></li>
								<li><a href={`/${lang}/video`} class="hover:text-primary transition-all">VIDEO</a></li>
							</ul>
						</div>
						<slot name="mobile-sidebar" />
					</div>
				</div>
			</div>
		</div>

		<!-- Scroll to Top Button (Alpine.js) -->
		<div x-data="{ scrolled: false }" x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 500 })">
			<button 
				x-show="scrolled"
				x-transition:enter="transition ease-out duration-300"
				x-transition:enter-start="opacity-0 translate-y-10"
				x-transition:enter-end="opacity-100 translate-y-0"
				x-transition:leave="transition ease-in duration-300"
				x-transition:leave-start="opacity-100 translate-y-0"
				x-transition:leave-end="opacity-0 translate-y-10"
				@click="window.scrollTo({ top: 0, behavior: 'smooth' })"
				class="fixed bottom-6 right-6 z-[90] btn btn-primary btn-circle shadow-2xl hover:scale-110 transition-transform"
				aria-label="Scroll to top"
			>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
				</svg>
			</button>
		</div>
	</body>
</html>

<style is:global>
	@reference "../styles/global.css";

	:root {
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
	}
	
	/* MS Support 스타일 본문 여백 및 가독성 조정 */
	.prose {
		max-width: 85ch;
		color: currentColor;
	}
	
	.prose h1, .prose h2, .prose h3 {
		@apply font-bold tracking-tight text-base-content;
	}
</style>
