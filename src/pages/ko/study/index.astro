---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';

const lang = "ko";
const posts = (await getCollection('study'))
  .filter(post => post.id.startsWith(lang + '/'))
  .sort((a, b) => {
    const orderA = a.data.order ?? 99;
    const orderB = b.data.order ?? 99;
    return orderA - orderB;
  });

// Extract categories dynamically and sort them
const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))].sort();

const t = {
  title: "STUDY",
  subtitle: "비파괴 검사(NDT) 및 초음파 탐상의 핵심 이론과 기술 정보입니다."
};
---

<BaseLayout title={t.title}>
  {/* Mobile Sidebar Slot */}
  <div slot="mobile-sidebar">
    <Sidebar type="study" />
  </div>

  <div class="flex flex-col lg:flex-row w-full max-w-[1600px] mx-auto min-h-screen bg-base-100 text-base-content">
    {/* Sidebar (Desktop) */}
    <div class="hidden lg:block w-[300px] shrink-0 border-r border-base-200">
        <Sidebar type="study" />
    </div>
    
    <div class="flex-grow p-8 lg:p-14">
      <div class="max-w-4xl">
        <header class="mb-20">
            <h1 class="text-[30px] font-bold text-base-content mb-3 tracking-tight">{t.title}</h1>
            <p class="text-[16px] text-base-content/50 font-medium">{t.subtitle}</p>
        </header>

        {/* Categories / Chapters - exact style matching Manual index */}
        {categories.map(cat => {
          const catPosts = posts.filter(p => p.data.category === cat);
          return (
            <section class="mb-24">
                <div class="w-full border-t border-base-200 pt-4 mb-10">
                    <h2 class="text-[12.5px] font-bold tracking-[0.12em] text-base-content/40 uppercase">
                        {cat.substring(cat.indexOf(' ') + 1)}
                    </h2>
                </div>
                <div class="flex flex-col gap-1">
                    {catPosts.map(post => {
                        const slug = post.id.replace(`${lang}/`, '');
                        const cleanTitle = post.data.title || slug.replace(/_/g, ' ').replace('.md', '');
                        return (
                            <a 
                              href={`/${lang}/study/${slug}`} 
                              class="group flex items-center justify-between py-6 border-b border-base-100/50 hover:bg-base-200/50 transition-all px-4 -mx-4 rounded-xl"
                            >
                                <div class="pr-8">
                                    <h3 class="text-[19px] font-bold text-base-content/90 mb-1.5 group-hover:text-primary transition-colors">
                                      {cleanTitle}
                                    </h3>
                                    <p class="text-[14.5px] text-base-content/50 font-medium leading-relaxed">
                                      {post.data.description}
                                    </p>
                                </div>
                                <div class="text-base-content/30 group-hover:text-primary transition-all transform group-hover:translate-x-1.5 shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
                                    </svg>
                                </div>
                            </a>
                        );
                    })}
                </div>
            </section>
          );
        })}
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  @reference "../../../styles/global.css";
</style>
