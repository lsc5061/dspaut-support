---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchArea from '../../components/SearchArea.astro';

const lang = "ko";

const t = {
	ko: {
		title: "도움이 필요하신가요?",
		subtitle: "장비 및 소프트웨어 사용법을 빠르게 찾아보세요.",
		manualTitle: "MANUAL",
		manualDesc: "장비 기술 사양, 소프트웨어 매뉴얼 및 설치 가이드를 확인하세요.",
		blogTitle: "BLOG",
		blogDesc: "업데이트 소식, 현장 적용 사례 및 기술 팁을 확인하세요.",
		studyTitle: "STUDY",
		studyDesc: "초음파의 기본 이론, 물리적 특성 및 탐상 기법을 학습하세요.",
		videoTitle: "VIDEO",
		videoDesc: "DSPAUT 유튜브 채널의 장비 조작 가이드 및 소프트웨어 튜토리얼을 시청하세요.",
		viewMore: "자세히 보기"
	}
}["ko"];
---

<BaseLayout title="DSPAUT Support">
	<div class="max-w-6xl mx-auto px-4 py-20 text-center">
		<h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">
			{t.title}
		</h1>
		<p class="text-lg text-base-content/70 mb-12">
			{t.subtitle}
		</p>

		<SearchArea />

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
			<a href={`/${lang}/manual`} class="group relative bg-base-100 border border-base-200 rounded-2xl p-7 text-left hover:-translate-y-2 hover:scale-[1.02] hover:shadow-2xl hover:shadow-primary/8 hover:border-primary/50 transition-all duration-500 flex flex-col h-full">
				<div class="mb-4 text-primary bg-primary/10 w-12 h-12 flex items-center justify-center rounded-xl group-hover:scale-110 transition-transform duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
					</svg>
				</div>
				<h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{t.manualTitle}</h2>
				<p class="text-[13.5px] text-base-content/60 mb-6 flex-grow leading-relaxed">{t.manualDesc}</p>
				<span class="text-primary font-semibold flex items-center gap-1.5 text-sm">
					{t.viewMore}
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</span>
			</a>

			<a href={`/${lang}/blog`} class="group relative bg-base-100 border border-base-200 rounded-2xl p-7 text-left hover:-translate-y-2 hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-500/8 hover:border-blue-500/50 transition-all duration-500 flex flex-col h-full">
				<div class="mb-4 text-blue-600 bg-blue-600/10 w-12 h-12 flex items-center justify-center rounded-xl group-hover:scale-110 transition-transform duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 13h8M8 17h8" />
					</svg>
				</div>
				<h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{t.blogTitle}</h2>
				<p class="text-[13.5px] text-base-content/60 mb-6 flex-grow leading-relaxed">{t.blogDesc}</p>
				<span class="text-primary font-semibold flex items-center gap-1.5 text-sm">
					{t.viewMore}
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</span>
			</a>

			<a href={`/${lang}/study`} class="group relative bg-base-100 border border-base-200 rounded-2xl p-7 text-left hover:-translate-y-2 hover:scale-[1.02] hover:shadow-2xl hover:shadow-purple-500/8 hover:border-purple-500/50 transition-all duration-500 flex flex-col h-full">
				<div class="mb-4 text-purple-600 bg-purple-600/10 w-12 h-12 flex items-center justify-center rounded-xl group-hover:scale-110 transition-transform duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14v7" />
					</svg>
				</div>
				<h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{t.studyTitle}</h2>
				<p class="text-[13.5px] text-base-content/60 mb-6 flex-grow leading-relaxed">{t.studyDesc}</p>
				<span class="text-primary font-semibold flex items-center gap-1.5 text-sm">
					{t.viewMore}
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</span>
			</a>

			<a href={`/${lang}/video`} class="group relative bg-base-100 border border-base-200 rounded-2xl p-7 text-left hover:-translate-y-2 hover:scale-[1.02] hover:shadow-2xl hover:shadow-rose-600/8 hover:border-rose-600/50 transition-all duration-500 flex flex-col h-full">
				<div class="mb-4 text-red-600 bg-red-600/10 w-12 h-12 flex items-center justify-center rounded-xl group-hover:scale-110 transition-transform duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
					</svg>
				</div>
				<h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{t.videoTitle}</h2>
				<p class="text-[13.5px] text-base-content/60 mb-6 flex-grow leading-relaxed">{t.videoDesc}</p>
				<span class="text-primary font-semibold flex items-center gap-1.5 text-sm">
					{t.viewMore}
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</span>
			</a>
		</div>
	</div>
</BaseLayout>
