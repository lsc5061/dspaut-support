---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = "en";
const rawPosts = (await getCollection('blog'))
  .filter(post => post.id.startsWith(lang + '/'))
  .sort((a, b) => {
    const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
    const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
    return dateB - dateA;
  });


// Pre-process posts for Alpine.js (serialize data correctly)
const posts = rawPosts.map(post => ({
  id: post.id,
  slug: post.id.replace(`${lang}/`, ''),
  data: {
    ...post.data,
    publishDate: post.data.publishDate.toISOString() 
  }
}));

const categories = ["All", "Field Case", "Technical Analysis", "Update News"];

const t = {
  title: "BLOG",
  subtitle: "Technical insights, case studies, and the latest updates from DSPAUT."
};
---

<BaseLayout title={t.title}>
  <div class="bg-base-100 min-h-screen">
    <header class="pt-12 pb-4 lg:pt-16 lg:pb-6 border-b border-base-200">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl">
          <h1 class="text-[40px] lg:text-[52px] font-black tracking-tight text-base-content leading-none mb-4">
            {t.title}
          </h1>
          <p class="text-[18px] lg:text-[20px] text-base-content/50 font-medium leading-relaxed">
            {t.subtitle}
          </p>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 lg:px-8 py-6 lg:py-8" x-data={`{ 
      lang: '${lang}',
      activeCategory: 'All',
      currentPage: 1,
      itemsPerPage: 9,
      posts: ${JSON.stringify(posts)},
      get filteredPosts() {
        if (this.activeCategory === 'All') return this.posts;
        return this.posts.filter(p => p.data.category === this.activeCategory);
      },
      get paginatedPosts() {
        const start = (this.currentPage - 1) * this.itemsPerPage;
        return this.filteredPosts.slice(start, start + this.itemsPerPage);
      },
      get totalPages() {
        return Math.ceil(this.filteredPosts.length / this.itemsPerPage);
      },
      formatDate(dateStr) {
        return new Date(dateStr).toLocaleDateString(this.lang === 'ko' ? 'ko-KR' : 'en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      }
    }`}>
      {/* Filters */}
      <div class="flex flex-wrap items-center gap-3 mb-8">
        {categories.map(cat => (
          <button 
            class="px-6 py-2.5 rounded-full text-[13.5px] font-bold tracking-tight transition-all"
            x-on:click={`activeCategory = '${cat}'; currentPage = 1`}
            x-bind:class={`activeCategory === '${cat}' ? 'bg-primary text-white shadow-lg shadow-primary/20 scale-105' : 'bg-base-200/50 text-base-content/50 hover:bg-base-200 hover:text-base-content'`}
          >
            {cat}
          </button>
        ))}
      </div>

      {/* Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 lg:gap-y-16">
        <template x-for="post in paginatedPosts" :key="post.id">
          <div class="flex flex-col h-full animate-fade-in-up">
            <article class="group flex flex-col h-full bg-base-100 rounded-2xl border border-base-200 overflow-hidden hover:shadow-2xl hover:shadow-primary/5 hover:border-primary/30 transition-all duration-500">
              <a :href="'/' + $data.lang + '/blog/' + post.slug" class="block overflow-hidden aspect-[16/9] bg-base-200">
                <img 
                  :src="post.data.image || '/images/placeholder-blog.jpg'" 
                  :alt="post.data.title" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </a>

              <div class="flex flex-col flex-grow p-6 lg:p-8">
                <div class="mb-4">
                  <span 
                    class="inline-block px-3 py-1 rounded-full text-[11px] font-bold tracking-wider uppercase"
                    :class="{
                      'bg-blue-50 text-blue-600': post.data.category === 'Field Case',
                      'bg-purple-50 text-purple-600': post.data.category === 'Technical Analysis',
                      'bg-emerald-50 text-emerald-600': post.data.category === 'Update News',
                      'bg-gray-50 text-gray-600': !post.data.category
                    }"
                    x-text="post.data.category || 'Uncategorized'"
                  ></span>
                </div>

                <h2 class="text-xl font-bold text-base-content mb-3 leading-snug group-hover:text-primary transition-colors line-clamp-2">
                  <a :href="'/' + $data.lang + '/blog/' + post.slug" x-text="post.data.title"></a>
                </h2>

                <p class="text-[14.5px] text-base-content/50 leading-relaxed line-clamp-3 mb-8 flex-grow" x-text="post.data.description"></p>

                <div class="flex items-center justify-between pt-6 border-t border-base-200 mt-auto">
                  <span class="text-xs font-medium text-base-content/40" x-text="formatDate(post.data.publishDate)"></span>
                  <div class="flex gap-2">
                    <template x-for="tag in (post.data.tags || []).slice(0, 2)">
                      <span class="text-[10px] font-bold text-base-content/30 uppercase tracking-tight" x-text="'#' + tag"></span>
                    </template>
                  </div>
                </div>
              </div>
            </article>
          </div>
        </template>
      </div>

      {/* Pagination */}
      <div class="mt-20 lg:mt-32 flex items-center justify-center gap-4" x-show="totalPages > 1">
        <button 
          class="btn btn-ghost btn-sm px-4" 
          :disabled="currentPage === 1"
          x-on:click="currentPage--; window.scrollTo({top: 0, behavior: 'smooth'})"
        >
          PREVIOUS
        </button>
        <div class="flex items-center gap-2">
          <template x-for="i in totalPages">
            <button 
              class="w-10 h-10 rounded-full font-bold text-sm transition-all"
              x-on:click="currentPage = i; window.scrollTo({top: 0, behavior: 'smooth'})"
              x-bind:class="currentPage === i ? 'bg-primary text-white' : 'hover:bg-base-200 text-base-content/40'"
              x-text="i"
            ></button>
          </template>
        </div>
        <button 
          class="btn btn-ghost btn-sm px-4" 
          :disabled="currentPage === totalPages"
          x-on:click="currentPage++; window.scrollTo({top: 0, behavior: 'smooth'})"
        >
          NEXT
        </button>
      </div>

      <div class="py-40 text-center" x-show="filteredPosts.length === 0">
        <p class="text-base-content/30 italic text-lg">Coming soon.</p>
      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
