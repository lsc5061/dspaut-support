---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const manuals = await getCollection('manuals');
  const paths = [];
  
  // 'en/'로 시작하는 문서만 필터링
  const enManuals = manuals.filter(entry => entry.id.startsWith('en/'));
  
  for (const entry of enManuals) {
    const relativeId = entry.id.replace('en/', '');
    
    if (relativeId.toLowerCase().includes('cm5')) {
      const filename = relativeId.split('/').pop();
      if (filename) {
        // B3용 가상 경로 추가
        const b3Id = relativeId.replace(filename, `DEEPSOUND_B3/${filename}`);
        paths.push({
          params: { slug: b3Id.toLowerCase().replace(/\\/g, '/') },
          props: { entry, virtualId: entry.id.replace(filename, `DEEPSOUND_B3/${filename}`) },
        });
        // T3용 가상 경로 추가
        const t3Id = relativeId.replace(filename, `DEEPSOUND_T3/${filename}`);
        paths.push({
          params: { slug: t3Id.toLowerCase().replace(/\\/g, '/') },
          props: { entry, virtualId: entry.id.replace(filename, `DEEPSOUND_T3/${filename}`) },
        });
      }
    } else {
      paths.push({
        params: { slug: relativeId.toLowerCase().replace(/\\/g, '/') },
        props: { entry },
      });
    }
  }
  return paths;
}

import { getCategoryInfo } from '../../../utils/category';

const { entry, virtualId } = Astro.props;
const { Content, headings } = await render(entry);

const lang = "en";

const displayTitle = getCategoryInfo(entry.id).sub;

const breadcrumbItems = [
  { label: 'MANUAL', href: `/${lang}/manual` },
  { label: displayTitle, href: '#' }
];
---

<BaseLayout title={`${displayTitle} - DSPAUT Support`}>
  <div slot="mobile-sidebar">
    <Sidebar activeSlug={virtualId || entry.id} type="manual" />
  </div>

  <div class="flex flex-col lg:flex-row w-full max-w-[1600px] mx-auto">
    <div class="hidden lg:block">
      <Sidebar activeSlug={virtualId || entry.id} type="manual" />
    </div>

    <div class="flex-grow min-w-0 bg-base-100 px-6 py-10 lg:px-12">
      <div class="max-w-4xl">
        <Breadcrumbs items={breadcrumbItems} />
        <header class="mb-12 border-b border-base-200 pb-8">
          <h1 class="text-4xl font-extrabold tracking-tight mb-4">{displayTitle}</h1>
          {entry.data.description && <p class="text-xl text-base-content/60 leading-relaxed">{entry.data.description}</p>}
        </header>
        <article class="prose prose-lg prose-slate dark:prose-invert max-w-none" data-pagefind-body>
          <Content />
        </article>
      </div>
    </div>

    <!-- Right Sidebar (TOC) -->
    <aside class="hidden xl:block w-64 flex-shrink-0 p-10 border-l border-base-200 h-screen sticky top-16 overflow-y-auto text-sm">
      <h3 class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-4">ON THIS PAGE</h3>
      <nav>
        <ul class="menu menu-sm p-0 gap-2">
          {headings.filter(h => h.depth <= 4).map(heading => (
            <li class={heading.depth === 3 ? "ml-4" : heading.depth === 4 ? "ml-8" : ""}>
              <a href={`#${heading.slug}`} class={`hover:text-primary py-1 transition-all ${heading.depth > 2 ? "opacity-60 text-xs" : "opacity-80"}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </div>
</BaseLayout>

<style is:global>
  @reference "../../../styles/global.css";
  
  /* Microsoft 스타일 본문 및 표 디자인 */
  .prose h1 { @apply mt-20 mb-10 text-base-content font-black border-b-4 border-base-200 pb-4; }
  .prose h2 { @apply mt-16 mb-8 text-base-content font-bold border-l-8 border-primary/30 pl-4; }
  .prose h3 { @apply mt-12 mb-6 text-base-content font-bold; }
  .prose h4 { @apply mt-8 mb-4 text-base-content font-semibold; }
  .prose p { @apply mb-6 leading-relaxed; }
  .prose li { @apply mb-2; }

  .prose img {
    @apply mx-auto rounded-xl shadow-md border border-base-200 my-12;
  }
  .prose table {
    @apply w-full border-collapse border border-base-300 my-8 text-sm;
  }
  .prose table thead {
    @apply bg-base-200 border-b-2 border-base-300;
  }
  .prose table th {
    @apply p-3 text-left font-bold text-base-content/80 uppercase tracking-wider border-r border-base-300;
  }
  .prose table td {
    @apply p-3 border-b border-r border-base-300 align-top;
  }
  .prose table tr:last-child td {
    @apply border-b-0;
  }
  .prose table th:last-child, .prose table td:last-child {
    @apply border-r-0;
  }
  .prose table tr:nth-child(even) {
    @apply bg-base-100/50;
  }

  /* Sticky TOC 하이라이트 스타일 */
  .toc-active {
    @apply text-primary font-bold border-l-2 border-primary pl-2 -ml-2 transition-all;
  }

  [id] { scroll-margin-top: 5rem; }
</style>

<script>
  import mermaid from 'mermaid';
  
  // 1. Mermaid 초기화 및 렌더링
  const initMermaid = () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? 'dark' : 'default',
      fontFamily: 'Inter, sans-serif',
      securityLevel: 'loose',
    });
  };

  initMermaid();

  // 2. TOC 활성화 스크립트 (Intersection Observer)
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -80% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const id = entry.target.getAttribute('id');
      const tocLink = document.querySelector(`aside nav a[href="#${id}"]`);
      if (entry.isIntersecting) {
        document.querySelectorAll('aside nav a').forEach(el => el.classList.remove('toc-active'));
        tocLink?.classList.add('toc-active');
      }
    });
  }, observerOptions);

  document.querySelectorAll('article h2, article h3').forEach((section) => {
    observer.observe(section);
  });
</script>
