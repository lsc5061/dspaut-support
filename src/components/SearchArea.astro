---
const lang = Astro.currentLocale || "ko";
const t = {
  ko: { placeholder: "무엇을 도와드릴까요?", noResults: "검색 결과가 없습니다." },
  en: { placeholder: "How can we help?", noResults: "No results found." }
}[lang as "ko" | "en"];
---

<div class="max-w-2xl mx-auto mb-16" x-data="{ query: '', results: [], open: false }">
  <div class="relative group">
    <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-base-content/40">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <input 
      type="text" 
      placeholder={t.placeholder}
      class="w-full pl-12 pr-4 py-4 rounded-lg border-2 border-base-200 focus:border-primary focus:outline-none bg-base-100 shadow-sm transition-all text-lg"
      x-model="query"
      @input.debounce.300ms="
        if (query.length > 1) {
          // Pagefind 검색 로직 (빌드 후 작동)
          try {
            const pagefind = await import('/pagefind/pagefind.js');
            const search = await pagefind.search(query);
            results = await Promise.all(search.results.slice(0, 5).map(r => r.data()));
            open = true;
          } catch(e) {
            console.log('Pagefind is not initialized yet. It will work after build.');
          }
        } else {
          open = false;
        }
      "
    />

    <!-- Search Results Dropdown -->
    <div 
      class="absolute w-full bg-base-100 mt-2 rounded-xl shadow-2xl border border-base-200 z-50 overflow-hidden"
      x-show="open && query.length > 1"
      x-transition
      @click.away="open = false"
    >
      <template x-if="results.length > 0">
        <div class="divide-y divide-base-200">
          <template x-for="result in results" :key="result.url">
            <a :href="result.url" class="block p-4 hover:bg-base-200 transition-colors">
              <div class="text-sm font-bold text-primary mb-1" x-text="result.meta.title"></div>
              <div class="text-xs text-base-content/60 line-clamp-2" x-html="result.excerpt"></div>
            </a>
          </template>
        </div>
      </template>
      
      <template x-if="results.length === 0">
        <div class="p-8 text-center text-base-content/40 italic text-sm">
          {t.noResults}
        </div>
      </template>
    </div>
  </div>
</div>
