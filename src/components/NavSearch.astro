---
const lang = Astro.currentLocale || "ko";
const t = {
  ko: { placeholder: "검색...", noResults: "검색 결과 없음" },
  en: { placeholder: "Search...", noResults: "No results" }
}[lang as "ko" | "en"];
---

<div 
  x-data="{ query: '', results: [], open: false, mobileOpen: false }"
  x-init="
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get('q');
    if (q) {
      query = q;
      $nextTick(async () => {
        try {
          const pagefind = await import('/pagefind/pagefind.js');
          const search = await pagefind.search(query);
          results = await Promise.all(search.results.slice(0, 5).map(r => r.data()));
          open = true;
          if ($refs.navSearchInput) $refs.navSearchInput.focus();
        } catch(e) {
          console.log('Pagefind not yet initialized');
        }
      });
    }
  "
  @window.keydown.slash.prevent="if (window.innerWidth >= 640) { $refs.navSearchInput.focus() } else { mobileOpen = true; $nextTick(() => $refs.mobileSearchInput.focus()) }"
  @window.keydown.meta.k.prevent="if (window.innerWidth >= 640) { $refs.navSearchInput.focus() } else { mobileOpen = true; $nextTick(() => $refs.mobileSearchInput.focus()) }"
  @window.keydown.ctrl.k.prevent="if (window.innerWidth >= 640) { $refs.navSearchInput.focus() } else { mobileOpen = true; $nextTick(() => $refs.mobileSearchInput.focus()) }"
>
  <!-- Desktop Search (hidden on mobile) -->
  <div class="relative hidden sm:block w-32 md:w-56 lg:w-64">
    <div class="relative group">
      <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none text-base-content/40">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input 
        x-ref="navSearchInput"
        type="text" 
        placeholder={t.placeholder}
        class="w-full pl-9 pr-10 py-1.5 rounded-full border border-base-300 focus:border-primary focus:outline-none bg-base-200/40 focus:bg-base-100 transition-all text-sm"
        x-model="query"
        @input.debounce.300ms="
          if (query.length > 1) {
            try {
              const pagefind = await import('/pagefind/pagefind.js');
              const search = await pagefind.search(query);
              results = await Promise.all(search.results.slice(0, 5).map(r => r.data()));
              open = true;
            } catch(e) {
              console.log('Pagefind not yet initialized');
            }
          } else {
            open = false;
          }
        "
        @keydown.escape="open = false; query = ''; $el.blur()"
      />
      <div class="absolute inset-y-0 right-3 flex items-center pointer-events-none">
        <kbd class="kbd kbd-xs bg-base-300/30 border-none opacity-40 text-[10px]">/</kbd>
      </div>

      <!-- Search Results Dropdown -->
      <div 
        class="absolute right-0 w-[300px] md:w-[400px] bg-base-100 mt-2 rounded-xl shadow-2xl border border-base-200 z-[60] overflow-hidden"
        x-show="open && query.length > 1"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-1"
        x-transition:enter-end="opacity-100 translate-y-0"
        @click.away="open = false"
      >
        <template x-if="results.length > 0">
          <div class="divide-y divide-base-200">
            <template x-for="result in results" :key="result.url">
              <a :href="result.url" class="block p-3 hover:bg-base-200 transition-colors group/item">
                <div class="text-xs font-bold text-primary mb-0.5 group-hover/item:underline" x-text="result.meta.title"></div>
                <div class="text-[10px] text-base-content/60 line-clamp-1" x-html="result.excerpt"></div>
              </a>
            </template>
          </div>
        </template>
        
        <template x-if="results.length === 0">
          <div class="p-4 text-center text-base-content/40 italic text-xs">
            {t.noResults}
          </div>
        </template>
      </div>
    </div>
  </div>

  <!-- Mobile Search Button -->
  <button 
    class="btn btn-ghost btn-circle btn-sm sm:hidden opacity-60"
    @click="mobileOpen = true; $nextTick(() => $refs.mobileSearchInput.focus())"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <!-- Mobile Search Modal (Full-screen overlay) -->
  <div 
    class="fixed inset-0 z-[100] bg-base-100 flex flex-col p-4 sm:hidden"
    x-show="mobileOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-4"
    @keydown.escape.window="mobileOpen = false"
    style="display: none;"
  >
    <!-- Modal Header -->
    <div class="flex items-center gap-2 mb-4">
      <button 
        class="btn btn-ghost btn-circle btn-sm" 
        @click="mobileOpen = false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </button>
      <div class="relative flex-grow">
        <input 
          x-ref="mobileSearchInput"
          type="text" 
          placeholder={t.placeholder}
          class="w-full pl-9 pr-8 py-2 rounded-full border border-base-300 focus:border-primary focus:outline-none bg-base-200/50 text-sm"
          x-model="query"
          @input.debounce.300ms="
            if (query.length > 1) {
              try {
                const pagefind = await import('/pagefind/pagefind.js');
                const search = await pagefind.search(query);
                results = await Promise.all(search.results.slice(0, 5).map(r => r.data()));
              } catch(e) {
                console.log('Pagefind not yet initialized');
              }
            } else {
              results = [];
            }
          "
        />
        <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none text-base-content/40 z-10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <button 
          class="absolute inset-y-0 right-3 flex items-center text-base-content/40 hover:text-base-content z-10 cursor-pointer"
          x-show="query.length > 0"
          @click="query = ''; results = []"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Search Results / Empty State -->
    <div class="flex-grow overflow-y-auto px-2">
      <template x-if="query.length > 1 && results.length > 0">
        <div class="divide-y divide-base-200">
          <template x-for="result in results" :key="result.url">
            <a :href="result.url" class="block py-4 border-b border-base-200/60">
              <div class="text-sm font-bold text-primary mb-1" x-text="result.meta.title"></div>
              <div class="text-xs text-base-content/70 line-clamp-2" x-html="result.excerpt"></div>
            </a>
          </template>
        </div>
      </template>
      <template x-if="query.length > 1 && results.length === 0">
        <div class="py-12 text-center text-base-content/40 italic text-sm">
          {t.noResults}
        </div>
      </template>
    </div>
  </div>
</div>

