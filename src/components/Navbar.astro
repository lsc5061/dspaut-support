---
import ThemeToggle from "./ThemeToggle.astro";
import NavSearch from "./NavSearch.astro";

const lang = Astro.currentLocale || "ko";

const t = {
	ko: {
		manual: "MANUAL",
		blog: "BLOG",
		study: "STUDY",
		video: "VIDEO",
		support: "Support Home",
	},
	en: {
		manual: "MANUAL",
		blog: "BLOG",
		study: "STUDY",
		video: "VIDEO",
		support: "Support Home",
	}
}[lang as "ko" | "en"];
---

<nav class="navbar bg-base-100/80 backdrop-blur-md border-b border-base-200 px-4 md:px-12 h-16 sticky top-0 z-50">
  <!-- Logo (Left) -->
  <div class="navbar-start">
    <a href={`/${lang}`} class="text-xl font-bold tracking-tight hover:opacity-80 transition-opacity flex items-center">
      <img src="/favicon.png" alt="DSPAUT Logo" class="h-8 w-8 object-contain mr-2" />
      DSPAUT <span class="font-normal opacity-60 ml-2 text-sm border-l pl-2 border-base-300">Support</span>
    </a>
  </div>

  <!-- Main Menu (Center) - Hidden on small screens, Search takes priority -->
  <div class="navbar-center hidden lg:flex gap-10 text-sm font-semibold">
    <a href={`/${lang}/manual`} class="hover:text-primary transition-colors opacity-80 hover:opacity-100 tracking-wider">{t.manual}</a>
    <a href={`/${lang}/blog`} class="hover:text-primary transition-colors opacity-80 hover:opacity-100 tracking-wider">{t.blog}</a>
    <a href={`/${lang}/study`} class="hover:text-primary transition-colors opacity-80 hover:opacity-100 tracking-wider">{t.study}</a>
    <a href={`/${lang}/video`} class="hover:text-primary transition-colors opacity-80 hover:opacity-100 tracking-wider">{t.video}</a>
  </div>

  <!-- End Controls (Right) -->
  <div class="navbar-end gap-2">
    <!-- Search Component Integrated -->
    <NavSearch />

    <!-- Language Switch (Restored to EN / KO order) -->
    <div class="flex items-center gap-1 mx-2 text-[10px] font-bold">
      <a href="/en" class={`px-2 py-1 rounded transition-colors ${lang === 'en' ? 'bg-primary text-white' : 'hover:bg-base-200 opacity-50'}`}>EN</a>
      <a href="/ko" class={`px-2 py-1 rounded transition-colors ${lang === 'ko' ? 'bg-primary text-white' : 'hover:bg-base-200 opacity-50'}`}>KO</a>
    </div>

    <!-- Dark Mode Toggle -->
    <ThemeToggle />
    
    <!-- Mobile Menu Button -->
    <label for="mobile-drawer" class="btn btn-ghost btn-sm btn-circle lg:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>
</nav>
